# =====================================
# BACKEND ENVIRONMENT VARIABLES
# =====================================

# Database Configuration
# Use DATABASE_URL in production platforms like Render/Railway.
DATABASE_URL=
DB_SSL=false
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_HOST=localhost
DB_PORT=5432

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-jwt-secret
JWT_EXPIRY=7d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# =====================================
# Google Maps API — Smart Route Matching
# =====================================
# Add your key below to activate:
#   ✅ Real geodistance-based route matching (Distance Matrix API)
#   ✅ Address geocoding on route creation (Geocoding API)
#   ✅ Travel time estimates on routes
# Without this key, the system falls back to text-similarity matching.
# Required APIs: Distance Matrix, Geocoding, Directions
GOOGLE_MAPS_API_KEY=


# =====================================
# FRONTEND ENVIRONMENT VARIABLES (.env.local in etms-frontend2/)
# =====================================
# VITE_API_URL=http://localhost:5000/api
